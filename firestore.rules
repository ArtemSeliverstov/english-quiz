rules_version = '2';

// Append-only-leaning rules. Reads stay open; writes stay open for the PWA
// and tools/*.js, but `delete` is locked everywhere and `exercises` is
// write-once.
//
// Threat model: the project ID is visible in the PWA bundle, so the Firestore
// endpoint is reachable from anywhere. The pre-existing `if true` rule meant
// anyone could wipe player documents. These rules keep PWA + tools/* working
// while closing that hole. Backups land in the `backups` branch weekly via
// .github/workflows/backup.yml as the recovery path.
//
// Deploy: `cd D:/Claude/english-quiz-repo && firebase deploy --only firestore:rules`
// (requires firebase CLI auth as a project owner). Verify in Firebase Console →
// Firestore → Rules.

service cloud.firestore {
  match /databases/{database}/documents {

    match /players/{playerName} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if false;

      // Exercise history — write-once. Once logged, never modified or deleted.
      match /exercises/{exerciseId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if false;
      }

      match /coach_sessions/{sessionId} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if false;
      }

      match /spelling_log/{ts} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if false;
      }

      match /medals_history/{weekIso} {
        allow read: if true;
        allow create, update: if true;
        allow delete: if false;
      }
    }

    // Exercise library. Reads must stay open — the PWA Coach picker lists
    // library content via fsList from the browser without auth. Writes stay
    // open too because tools/push_library.js writes via the same anonymous
    // REST path. Threat surface: anyone with the project ID can wipe library
    // content. Acceptable because (a) library_drafts/*.json in the repo is
    // the source of truth — every push is reproducible from disk, and
    // (b) the weekly backups workflow snapshots state. Re-evaluate if
    // push_library.js migrates to a service-account write path; at that
    // point lock writes to `if false`.
    match /exercises_library/{document=**} {
      allow read, write: if true;
    }

    // Math Sprint family leaderboard (mathsprint.html, 2026-07-11). One doc per
    // RUN — `{player}__{mode}__{length}__{ts}` — so the board is a long ranked
    // list (minesweeper "Times" style), not one row per player. NOT learning data:
    // only game time/errors/date, isolated from players/{name}. Deliberate §6
    // exception — competition is the requested motivator for the math track
    // (references/design-decisions.md). Runs are immutable (no update). Delete is
    // open because the client prunes each combo to the top-50 and the game offers
    // per-row / whole-board delete (both PIN-gated to Artem in the UI). Same
    // risk posture as `exercises_library`: worst case is lost game times (no
    // learning data), and the nightly backup workflow snapshots Firestore.
    match /math_sprint_scores/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if true;
    }

    // Memory trainer family board (memory.html, 2026-07-24). Same posture as
    // math_sprint_scores: one immutable doc per run — `{player}__{mode}__{ts}`,
    // game scores only (level/err/date), isolated from players/{name}. Client
    // prunes each mode to top-50; deletes are Artem-PIN-gated in the UI.
    match /memory_trainer_scores/{id} {
      allow read: if true;
      allow create: if true;
      allow update: if false;
      allow delete: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
