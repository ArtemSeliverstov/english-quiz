{
    "$schema":  "https://json.schemastore.org/claude-code-settings.json",
    "memory":  {
                   "autoMemoryEnabled":  false,
                   "_comment":  "Auto-memory disabled per s88 architecture decision. Workflow is mobile-first; auto-memory is laptop-filesystem-only and would not sync across surfaces. Family-related dynamic learnings live in Firestore players/{name}.coach_notes вЂ” see references/coach-notes-schema.md."
               },
    "tools":  {
                  "_comment":  "Default tool permissions. Firebase MCP plugin tools are auto-enabled when plugin loads. Bash/file editing tools always available."
              },
    "enabledMcpjsonServers":  [
                                  "firebase"
                              ],
    "permissions":  {
                        "allow":  [
                                      "Bash(node --check *)",
                                      "Bash(node tools/get_player.js *)",
                                      "Bash(node tools/get_all_players.js *)",
                                      "Bash(node tools/check_transform_keywords.js *)",
                                      "mcp__Claude_Preview__preview_console_logs",
                                      "mcp__Claude_Preview__preview_screenshot",
                                      "mcp__Claude_Preview__preview_snapshot",
                                      "mcp__Claude_Preview__preview_start"
                                  ]
                    }
}

