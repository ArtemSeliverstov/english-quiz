# Credentials and secrets — never commit
.env
.env.local
.env.*.local
*.pem
*-key.json
service_account*.json
worker/.dev.vars
worker/.wrangler/

# Node
node_modules/
npm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Local Claude Code state — settings & skills ARE committed; per-machine overrides are not
.claude/settings.local.json
.claude/projects/
.claude/sessions/
.claude/conversations/
.claude/cache/
.claude/tmp/
.claude/worktrees/

# Personal materials kept in repo dir but not committed (README house rule 5 —
# Interview/ is the one sanctioned local-only exception)
Interview/

# Local artefacts
*.log
/tmp/

# Local backup snapshots — production backups go to the `backups` branch via
# .github/workflows/backup.yml. Anything in this directory on `main` is a
# manual run (e.g. tools/backup_players.js without --remote) and stays local.
backups/

# index.html backup snapshots from migration scripts (rollback points, not history —
# delete after the migration ships; git history is the real rollback)
index.html.pre_*.bak
index.html.*.bak

# One-off script guard: per README house rule 1, one-offs run from the session
# scratchpad and never enter the repo — no per-file ignore list needed anymore.
# Misc scratch guards for legacy tool outputs:
parsed_questions.json
temp_questions.js
all_players_tmp.json
stratified_sample*.md
