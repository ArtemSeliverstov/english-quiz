# Credentials and secrets — never commit
.env
.env.local
.env.*.local
*.pem
*-key.json
service_account*.json
worker/.dev.vars
worker/.wrangler/

# Node
node_modules/
npm-debug.log*

# Editor / OS
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/

# Local Claude Code state — settings & skills ARE committed; per-machine overrides are not
.claude/settings.local.json
.claude/projects/
.claude/sessions/
.claude/conversations/
.claude/cache/

# Local artefacts
*.log
/tmp/

# Local backup snapshots — production backups go to the `backups` branch via
# .github/workflows/backup.yml. Anything in this directory on `main` is a
# manual run (e.g. tools/backup_players.js without --remote) and stays local.
backups/

# index.html backup snapshots from migration scripts (rollback points, not history)
index.html.pre_*.bak
index.html.*.bak

# Wave-authoring scratch (one-shot scripts + intermediate JSON kept local)
tools/batches/
tools/wave*_*.json
tools/wave*_rubric.md
tools/wave*_apply.js
tools/wordform_*.json
tools/wordform_export.js
tools/wordform_base_apply.js
